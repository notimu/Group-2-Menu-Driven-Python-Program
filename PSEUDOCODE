43. DEFINE FUNCTION _normalize_paragraphs WITH PARAMETER lines
    INITIALIZE normalized TO empty list
    FOR EACH line IN lines
        IF NOT line THEN
            APPEND "" TO normalized
            CONTINUE
        ENDIF
        EXTEND normalized WITH textwrap.wrap(line, width = MENU_WIDTH - 4) OR [""]
    END FOR
    RETURN normalized
44. END FUNCTION

45. DEFINE FUNCTION _normalize_code_lines WITH PARAMETER lines
    INITIALIZE normalized TO empty list
    SET max_width TO MENU_WIDTH - 4

    FOR EACH line IN lines
        SET expanded_line TO line.expandtabs(4)

        IF expanded_line IS EQUAL TO "" THEN
            APPEND "" TO normalized
            CONTINUE
        ENDIF

        SET indent_width TO LENGTH(expanded_line) MINUS LENGTH(expanded_line.lstrip(" "))
        SET indent TO " " MULTIPLIED BY MINIMUM(indent_width, max_width - 1)
        SET content TO expanded_line[indent_width:]
        SET available_width TO MAXIMUM(1, max_width - LENGTH(indent))
        SET wrapped_lines TO textwrap.wrap(content, width = available_width, replace_whitespace = False, drop_whitespace = False) OR [""]

        APPEND indent + wrapped_lines[0] TO normalized

        FOR EACH wrapped_line IN wrapped_lines FROM INDEX 1 ONWARD
            APPEND indent + wrapped_line TO normalized
        END FOR
    END FOR

    RETURN normalized
46. END FUNCTION

47. DEFINE FUNCTION _pad_section_lines WITH PARAMETERS lines, top_padding = 1, bottom_padding = 1
    RETURN ([""] MULTIPLIED BY top_padding) + CALL _normalize_paragraphs(lines) + ([""] MULTIPLIED BY bottom_padding)
48. END FUNCTION

49. DEFINE FUNCTION _format_option_lines WITH PARAMETER option_lines
    INITIALIZE spaced_lines TO empty list
    FOR EACH line IN option_lines WITH index
        APPEND line TO spaced_lines
        IF line IS NOT EMPTY AND index IS NOT EQUAL TO LENGTH(option_lines) - 1 THEN
            APPEND "" TO spaced_lines
        ENDIF
    END FOR
    RETURN spaced_lines
50. END FUNCTION

51. DEFINE FUNCTION _print_border WITH PARAMETERS left, fill, right
    PRINT left + fill MULTIPLIED BY (MENU_WIDTH - 2) + right
52. END FUNCTION

53. DEFINE FUNCTION _print_box_lines WITH PARAMETERS lines, align = "left"
    FOR EACH line IN lines
        IF align IS "center" THEN
            SET text TO centered line with width MENU_WIDTH - 4
        ELSE
            SET text TO left-justified line with width MENU_WIDTH - 4
        ENDIF
        PRINT VERTICAL + " " + text + " " + VERTICAL
    END FOR
54. END FUNCTION

55. DEFINE FUNCTION _call_menu_function WITH PARAMETER function_name
    SET function_obj TO globals().get(function_name)
    IF callable(function_obj) THEN
        CALL function_obj()
    ELSE
        PRINT "Menu error: " + function_name + " was not found."
        CALL pause
    ENDIF
56. END FUNCTION

57. DEFINE FUNCTION render_menu_screen WITH PARAMETERS title_lines, prologue_lines, option_lines, epilogue_lines
    CALL _print_border(TOP_LEFT, HORIZONTAL, TOP_RIGHT)
    CALL _print_box_lines(_pad_section_lines(title_lines), "center")
    CALL _print_border(TITLE_DIVIDER_LEFT, HORIZONTAL, TITLE_DIVIDER_RIGHT)
    CALL _print_box_lines(_pad_section_lines(prologue_lines))
    CALL _print_border(SECTION_DIVIDER_LEFT, HORIZONTAL, SECTION_DIVIDER_RIGHT)
    CALL _print_box_lines(_pad_section_lines(_format_option_lines(option_lines)))
    CALL _print_border(SECTION_DIVIDER_LEFT, HORIZONTAL, SECTION_DIVIDER_RIGHT)
    CALL _print_box_lines(_pad_section_lines(epilogue_lines))
    CALL _print_border(BOTTOM_LEFT, HORIZONTAL, BOTTOM_RIGHT)
58. END FUNCTION

59. DEFINE FUNCTION render_content_screen WITH PARAMETERS title_lines, content_lines, epilogue_lines
    CALL _print_border(TOP_LEFT, HORIZONTAL, TOP_RIGHT)
    CALL _print_box_lines(_pad_section_lines(title_lines), "center")
    CALL _print_border(TITLE_DIVIDER_LEFT, HORIZONTAL, TITLE_DIVIDER_RIGHT)
    CALL _print_box_lines([""] + _normalize_code_lines(content_lines) + [""])
    CALL _print_border(SECTION_DIVIDER_LEFT, HORIZONTAL, SECTION_DIVIDER_RIGHT)
    CALL _print_box_lines(_pad_section_lines(epilogue_lines))
    CALL _print_border(BOTTOM_LEFT, HORIZONTAL, BOTTOM_RIGHT)
60. END FUNCTION

61. DEFINE FUNCTION show_menu WITH PARAMETERS menu_title, menu_options, back_label, drawer_path
    SET option_lines TO list of strings formatted as choice + " - " + label FOR EACH choice, (label, _) IN menu_options
    APPEND GO_BACK_CHOICE + " - " + back_label TO option_lines
    CALL render_menu_screen WITH
        title_lines = [menu_title]
        prologue_lines = ["Current location: " + joined drawer_path with " > ", "Choose a number from the list below, then press Enter."]
        option_lines = option_lines
        epilogue_lines = ["Type " + GO_BACK_CHOICE + " to " + lowercase(back_label) + "."]
62. END FUNCTION

63. DEFINE FUNCTION run_menu WITH PARAMETERS menu_title, menu_options, back_label, drawer_path = None
    SET valid_choices TO list of menu_options keys PLUS GO_BACK_CHOICE
    SET current_path TO drawer_path IF drawer_path EXISTS, OTHERWISE [menu_title]

    WHILE True
        CALL show_menu WITH menu_title, menu_options, back_label, current_path
        SET choice TO CALL get_choice(valid_choices)

        IF choice IS EQUAL TO GO_BACK_CHOICE THEN
            RETURN
        ENDIF

        UNPACK menu_options[choice] INTO ignored label, function_name
        CALL _call_menu_function(function_name)
    END WHILE
64. END FUNCTION

65. DEFINE FUNCTION run_activity_menu WITH PARAMETERS menu_title, activities, drawer_path = None
    SET current_path TO drawer_path IF drawer_path EXISTS, OTHERWISE [menu_title]

    WHILE True
        SET option_lines TO list of strings formatted as i + " - " + item[0] FOR EACH i, item IN activities STARTING AT 1
        APPEND GO_BACK_CHOICE + " - Go back" TO option_lines

        CALL render_menu_screen WITH
            title_lines = [menu_title]
            prologue_lines = ["Current location: " + joined current_path with " > ", "Open an activity from the list below."]
            option_lines = option_lines
            epilogue_lines = ["Select an item number to continue."]

        SET valid_choices TO list of string numbers from 1 to LENGTH(activities)
        APPEND GO_BACK_CHOICE TO valid_choices

        SET choice TO CALL get_choice(valid_choices)

        IF choice IS EQUAL TO GO_BACK_CHOICE THEN
            RETURN
        ENDIF

        SET activity_index TO INTEGER(choice) - 1
        UNPACK activities[activity_index] INTO activity_title, activity_function

        WHILE True
            CALL render_menu_screen WITH
                title_lines = [activity_title]
                prologue_lines = ["Current location: " + joined current_path with " > ", "You can inspect the code first or run the activity now."]
                option_lines = ["1 - View Code", "2 - Run Activity", GO_BACK_CHOICE + " - Go back"]
                epilogue_lines = ["Choose how you want to continue."]

            SET activity_choice TO CALL get_choice(["1", "2", GO_BACK_CHOICE])

            IF activity_choice IS EQUAL TO GO_BACK_CHOICE THEN
                BREAK
            ENDIF

            IF activity_choice IS "1" THEN
                CALL view_function_code(activity_function, activity_title)
                CONTINUE
            ENDIF

            CALL activity_function()
            BREAK
        END WHILE
    END WHILE
66. END FUNCTION

67. DEFINE FUNCTION quiz_menu WITH PARAMETERS topic_title, quiz_title, quiz_data, drawer_path = None
