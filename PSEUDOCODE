71. DEFINE FUNCTION count_number_types WITH PARAMETER numbers
    INITIALIZE positive_count TO 0
    INITIALIZE negative_count TO 0
    INITIALIZE zero_count TO 0

    FOR EACH number IN numbers
        IF number > 0 THEN
            INCREMENT positive_count BY 1
        ELIF number < 0 THEN
            INCREMENT negative_count BY 1
        ELSE
            INCREMENT zero_count BY 1
        ENDIF
    END FOR

    RETURN positive_count, negative_count, zero_count
72. END FUNCTION

