143. DEFINE FUNCTION analyze_csv WITH PARAMETERS filename, column_name, analysis_type
    TRY
        OPEN filename IN READ MODE AS file
            INITIALIZE reader TO csv.DictReader(file)
            INITIALIZE values TO empty list

            FOR EACH row IN reader
                APPEND float(row[column_name]) TO values
            END FOR
        CLOSE file

        IF analysis_type IS "mean" THEN
            SET result TO statistics.mean(values)
        ELIF analysis_type IS "median" THEN
            SET result TO statistics.median(values)
        ELIF analysis_type IS "mode" THEN
            SET result TO statistics.mode(values)
        ELSE
            PRINT "Invalid analysis type. Use mean, median, or mode."
            RETURN
        ENDIF

        PRINT "The " + analysis_type + " of the " + column_name + " column is: " + result formatted to 2 decimal places
    CATCH FileNotFoundError
        PRINT "Error: File not found."
    CATCH KeyError
        PRINT "Error: Column name not found."
    CATCH ValueError
        PRINT "Error: Column contains non-numeric values."
    CATCH statistics.StatisticsError
        PRINT "Error: Could not compute mode."
    END TRY
144. END FUNCTION

