113. DEFINE FUNCTION file_item1_merge_files
    PRINT "CodeChum Semi-Finals - Lesson 6 - Topic 1 - Item 1: Merge Two Text Files"

    OPEN "file1.txt" IN WRITE MODE AS file1
        WRITE "This is the contents of file 1.\nIt contains some random text.\n" TO file1
    CLOSE file1

    OPEN "file2.txt" IN WRITE MODE AS file2
        WRITE "This is the contents of file 2.\nIt also contains some random text.\n" TO file2
    CLOSE file2

    PRINT "Sample files created: file1.txt and file2.txt"

    INPUT file_name1
    SET file_name1 TO stripped value

    INPUT file_name2
    SET file_name2 TO stripped value

    TRY
        OPEN file_name1 IN READ MODE AS f1
    CATCH FileNotFoundError
        PRINT "Error: Could not open file " + file_name1 + "."
        CALL pause
        RETURN
    END TRY

    TRY
        OPEN file_name2 IN READ MODE AS f2
    CATCH FileNotFoundError
        PRINT "Error: Could not open file " + file_name2 + "."
        CLOSE f1
        CALL pause
        RETURN
    END TRY

    INPUT new_name
    SET new_name TO stripped value

    OPEN new_name IN WRITE MODE AS new_file
        WRITE f1.read() TO new_file
        WRITE f2.read() TO new_file
    CLOSE new_file

    CLOSE f1
    CLOSE f2

    PRINT "Files merged successfully."
    CALL pause
114. END FUNCTION

