27. DEFINE FUNCTION get_choice WITH PARAMETER valid_choices
    WHILE True
        INPUT choice
        SET choice TO stripped input
        IF choice IS IN valid_choices THEN
            CALL clear_console
            RETURN choice
        ENDIF
        PRINT "Invalid choice. Please try again."
    END WHILE
28. END FUNCTION

29. DEFINE FUNCTION get_int WITH PARAMETER prompt
    WHILE True
        TRY
            RETURN integer value of stripped INPUT(prompt)
        CATCH ValueError
            PRINT "Invalid input. Please enter a whole number."
        END TRY
    END WHILE
30. END FUNCTION

31. DEFINE FUNCTION view_function_code WITH PARAMETERS function_obj, title
    CALL clear_console
    TRY
        SET source_lines TO inspect.getsource(function_obj).splitlines()
    CATCH OSError OR TypeError
        SET source_lines TO list containing "Unable to display the source code for this item."
    END TRY
    CALL render_content_screen WITH
        title_lines = ["Code Preview: " + title]
        content_lines = source_lines
        epilogue_lines = ["Press Enter to continue."]
    CALL pause
32. END FUNCTION

33. DEFINE FUNCTION review_quiz_attempt WITH PARAMETERS quiz_title, review_items, score, total_questions
    WHILE True
        CALL render_menu_screen WITH
            title_lines = [quiz_title, "Quiz Review"]
            prologue_lines = ["Score: " + score + "/" + total_questions, "Review each question, your answer, and the correct answer below."]
            option_lines = review_items
            epilogue_lines = ["1 - Return to quiz menu"]
        SET choice TO CALL get_choice(["1"])
        IF choice IS "1" THEN
            RETURN
        ENDIF
    END WHILE
34. END FUNCTION

35. DEFINE FUNCTION run_quiz WITH PARAMETERS quiz_title, questions
    PRINT quiz_title
    INITIALIZE letters TO ["A", "B", "C", "D"]
    INITIALIZE score TO 0
    INITIALIZE review_items TO empty list

    FOR EACH item IN questions WITH number STARTING AT 1
        UNPACK item INTO question, choices, answer
        PRINT "\n" + number + ". " + question

        FOR EACH choice IN choices WITH i STARTING AT 0
            PRINT "   " + letters[i] + ". " + choice
        END FOR

        INPUT user_answer
        CONVERT user_answer TO stripped uppercase value

        WHILE user_answer IS NOT IN letters
            PRINT "Please enter A, B, C, or D only."
            INPUT user_answer
            CONVERT user_answer TO stripped uppercase value
        END WHILE

        IF user_answer IS EQUAL TO answer THEN
            PRINT "Correct!"
            INCREMENT score BY 1
            SET result_text TO "Correct"
        ELSE
            SET correct_index TO index of answer in letters
            PRINT "Wrong. Correct answer: " + answer + ". " + choices[correct_index]
            SET result_text TO "Wrong"
        ENDIF

        SET user_index TO index of user_answer in letters
        SET correct_index TO index of answer in letters

        EXTEND review_items WITH
            number + ". " + question
            "   Your answer: " + user_answer + ". " + choices[user_index]
            "   Correct answer: " + answer + ". " + choices[correct_index]
            "   Result: " + result_text
            blank line
    END FOR

    PRINT "\nFinal score: " + score + "/" + LENGTH(questions)
    PRINT "1. Review quiz"
    PRINT "0. Back"

    SET choice TO CALL get_choice(["1", GO_BACK_CHOICE])

    IF choice IS "1" THEN
        CALL review_quiz_attempt WITH quiz_title, review_items, score, LENGTH(questions)
    ENDIF
36. END FUNCTION

