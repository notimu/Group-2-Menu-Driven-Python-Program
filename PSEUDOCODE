131. DEFINE FUNCTION csv_item2_remove_duplicates
    PRINT "CodeChum Semi-Finals - Lesson 6 - Topic 2 - Item 2: Remove Duplicate Products"

    FOR EACH i FROM 1 TO 4
        CALL create_sample_csv("sample" + i + ".csv", i)
    END FOR

    PRINT "Sample CSV files created: sample1.csv, sample2.csv, sample3.csv, sample4.csv"

    WHILE True
        INPUT filename
        SET filename TO stripped value
        IF os.path.exists(filename) THEN
            BREAK
        ENDIF
        PRINT "Error: Input file does not exist."
    END WHILE

    INITIALIZE seen TO empty set
    INITIALIZE rows TO empty list

    OPEN filename IN READ MODE AS file
        INITIALIZE reader TO csv.reader(file)
        SET header TO next(reader)

        FOR EACH row IN reader
            IF LENGTH(row) < 2 THEN
                CONTINUE
            ENDIF

            SET key TO (row[0], row[1])

            IF key IS NOT IN seen THEN
                ADD key TO seen
                APPEND row TO rows
            ENDIF
        END FOR
    CLOSE file

    OPEN "output.csv" IN WRITE MODE AS file
        INITIALIZE writer TO csv.writer(file)
        WRITE ROW header
        WRITE all rows
    CLOSE file

    PRINT "Duplicate products removed successfully! Output saved to output.csv"
    CALL pause
132. END FUNCTION

