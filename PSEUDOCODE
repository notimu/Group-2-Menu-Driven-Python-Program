            option_lines = ["1 - Take Quiz", GO_BACK_CHOICE + " - Go back"]
            epilogue_lines = ["Start the quiz from this screen."]

        SET choice TO CALL get_choice(["1", GO_BACK_CHOICE])

        IF choice IS "1" THEN
            CALL run_quiz(quiz_title, quiz_data)
        ELSE
            RETURN
        ENDIF
    END WHILE
68. END FUNCTION

