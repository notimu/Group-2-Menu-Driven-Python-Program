135. DEFINE FUNCTION is_number WITH PARAMETER value
    TRY
        CONVERT value TO float
        RETURN True
    CATCH ValueError
        RETURN False
    END TRY
136. END FUNCTION

137. DEFINE FUNCTION csv_item3_clean_invalid_rows
    PRINT "CodeChum Semi-Finals - Lesson 6 - Topic 2 - Item 3: Clean Invalid Rows"
    CALL create_csv_samples_item3
    PRINT "Sample CSV files created: file1.csv, file2.csv, file3.csv"

    INPUT input_file
    SET input_file TO stripped value

    INPUT output_file
    SET output_file TO stripped value

    IF NOT os.path.exists(input_file) THEN
        PRINT "File does not exist."
        CALL pause
        RETURN
    ENDIF

    OPEN input_file IN READ MODE AS csvfile
        SET rows TO list(csv.reader(csvfile))
    CLOSE csvfile

    IF NOT rows THEN
        PRINT "Input CSV is empty."
        CALL pause
        RETURN
    ENDIF

    SET header TO rows[0]
    INITIALIZE cleaned_rows TO [header]

    FOR EACH row IN rows FROM INDEX 1 ONWARD
        IF LENGTH(row) != LENGTH(header) THEN
            CONTINUE
        ENDIF

        IF ANY stripped cell IS EMPTY IN row THEN
            CONTINUE
        ENDIF

        INITIALIZE valid TO True

        FOR EACH i FROM 1 TO LENGTH(row) - 1
            IF NOT CALL is_number(stripped value of row[i]) THEN
                SET valid TO False
                BREAK
            ENDIF
        END FOR

        IF valid THEN
            APPEND list of stripped cells in row TO cleaned_rows
        ENDIF
    END FOR

    OPEN output_file IN WRITE MODE AS csvfile
        WRITE cleaned_rows USING csv.writer(csvfile)
    CLOSE csvfile

    PRINT "Invalid rows removed successfully. Cleaned data written to " + output_file + "."
    CALL pause
138. END FUNCTION

